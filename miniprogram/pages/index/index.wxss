.memory-wrap {
  display: grid;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.memory-title {
  margin-bottom: 10rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.memory-desc {
  margin-bottom: 18rpx;
  color: #6b6b6b;
  font-size: 25rpx;
}

.submit {
  margin-top: 8rpx;
}

.advanced-section {
  padding: 0;
  overflow: hidden;
}

.advanced-toggle {
  width: 100%;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0;
  padding: 0 28rpx;
  border: 0;
  background: #fff;
  color: #1a1a1a;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.advanced-toggle::after {
  border: none;
}

.advanced-toggle-state {
  color: #ff6b35;
  font-size: 25rpx;
}

.advanced-panel {
  padding: 26rpx 28rpx 28rpx;
  border-top: 2rpx solid #ffe4d3;
}

.favorite-input-row {
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 16rpx;
}

.add-food-btn {
  min-height: 76rpx;
  border-radius: 16rpx;
  font-size: 27rpx;
  line-height: 76rpx;
}

.favorite-list {
  margin-top: 18rpx;
}

.advanced-hint {
  margin-top: 18rpx;
  color: #6b6b6b;
  font-size: 25rpx;
  line-height: 1.55;
}
