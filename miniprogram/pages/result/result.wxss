.result-header {
  padding-bottom: 18rpx;
}

.result-brand {
  font-size: 42rpx;
}

.summary {
  background: #fff5ee;
}

.summary-good {
  margin-bottom: 18rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.small-title {
  margin-top: 14rpx;
}

.plan-title {
  color: #ff6b35;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.plan-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.plan-meta text {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff8f2;
  color: #6b6b6b;
  font-size: 24rpx;
}

.plan-reason {
  margin-bottom: 18rpx;
  color: #6b6b6b;
  font-size: 26rpx;
  line-height: 1.6;
}

.plan-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: 16rpx 0 22rpx;
}

.block-title {
  margin: 28rpx 0 14rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.dish-row {
  padding: 16rpx 0;
  border-bottom: 2rpx dashed #ffe4d3;
}

.dish-name,
.recipe-name {
  margin-bottom: 6rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.shopping-group {
  margin-bottom: 16rpx;
}

.shopping-title {
  margin-bottom: 8rpx;
  color: #6b6b6b;
  font-size: 25rpx;
}

.shopping-items {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.shopping-item {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #fff8f2;
  font-size: 25rpx;
}

.timeline-row {
  display: flex;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx dashed #ffe4d3;
}

.timeline-time {
  width: 88rpx;
  color: #ff6b35;
  font-size: 26rpx;
  font-weight: 800;
}

.timeline-task {
  flex: 1;
  color: #1a1a1a;
  font-size: 26rpx;
  line-height: 1.55;
}

.step-row {
  margin-bottom: 10rpx;
  color: #6b6b6b;
  font-size: 26rpx;
  line-height: 1.65;
}

.recipe {
  padding: 18rpx 0;
  border-top: 2rpx dashed #ffe4d3;
}

.recipe-tips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.recipe-tip {
  max-width: 100%;
  padding: 8rpx 12rpx;
  border: 2rpx solid #ffe4d3;
  border-radius: 12rpx;
  background: #fffaf5;
  color: #2b2b2b;
  font-size: 23rpx;
  line-height: 1.45;
}

.mock-note {
  padding: 12rpx 20rpx 0;
  color: #6b6b6b;
  font-size: 23rpx;
  text-align: center;
}
